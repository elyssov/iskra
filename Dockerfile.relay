FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /relay ./cmd/relay/

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /relay /relay
EXPOSE 8443
ENTRYPOINT ["/relay"]
CMD ["-port", "8443"]
